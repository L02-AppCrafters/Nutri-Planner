# ── Image Recognition Provider ────────────────────────────────────────────────
# Choose "openai" or "google" (defaults to "openai" when not set).
RECOGNITION_PROVIDER=openai

# ── OpenAI API (used when RECOGNITION_PROVIDER=openai) ────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── Google Cloud Vision API (used when RECOGNITION_PROVIDER=google) ───────────
GOOGLE_VISION_API_KEY=your_google_cloud_vision_api_key_here

# ── Optional: override the network request timeout (milliseconds) ─────────────
# RECOGNITION_TIMEOUT_MS=15000
